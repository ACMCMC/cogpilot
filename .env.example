# CogPilot Environment Variables
# Copy this to .env and fill in your Snowflake credentials
# DO NOT COMMIT .env to git

SNOWFLAKE_ACCOUNT=your_account.region.snowflakecomputing.com
SNOWFLAKE_PAT_TOKEN=your_programmatic_access_token_here
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=COGPILOT_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=ACCOUNTADMIN
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
